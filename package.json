{
	"name": "rubato",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "VITE_DEV_GUI=true vite --host",
		"build": "tsc --noEmit && vite build",
		"preview": "vite preview",
		"lint": "biome check .",
		"format": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"check": "biome check . && tsc --noEmit && tsc --noEmit -p tsconfig.e2e.json && vite build",
		"screenshot": "npx playwright test e2e/preview.spec.ts --grep screenshot",
		"interact": "INTERACT=1 HEADED=1 npx playwright test e2e/preview.spec.ts --grep interact",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,js,json,jsonc,glsl}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/edobry/rubato.git"
	},
	"license": "ISC",
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@playwright/test": "^1.58.2",
		"@types/node": "^25.5.0",
		"@vitejs/plugin-basic-ssl": "^2.2.0",
		"husky": "^9.1.7",
		"lil-gui": "^0.21.0",
		"lint-staged": "^16.4.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.0",
		"vite-plugin-glsl": "^1.5.6",
		"vite-plugin-static-copy": "^3.3.0"
	},
	"dependencies": {
		"@mediapipe/tasks-vision": "^0.10.32"
	}
}
