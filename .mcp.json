{
	"mcpServers": {
		"cloudflare": {
			"command": "npx",
			"args": ["mcp-remote", "https://mcp.cloudflare.com/mcp"]
		},
		"fly": {
			"command": "fly",
			"args": ["mcp", "server"]
		},
		"playwright": {
			"command": "npx",
			"args": [
				"@playwright/mcp@latest",
				"--cdp-endpoint",
				"http://localhost:9222",
				"--ignore-https-errors",
				"--console-level",
				"info",
				"--caps",
				"devtools"
			]
		}
	}
}
