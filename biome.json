{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"recommended": false
			}
		}
	},
	"formatter": {
		"enabled": true
	},
	"files": {
		"includes": ["src/**", "*.json", "*.ts"]
	}
}
