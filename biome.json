{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"recommended": false
			},
			"nursery": {
				"noFloatingPromises": "error"
			},
			"suspicious": {
				"noImplicitAnyLet": "error",
				"useAwait": "warn"
			}
		}
	},
	"formatter": {
		"enabled": true
	},
	"files": {
		"includes": ["src/**", "e2e/**", "*.json", "*.ts"]
	}
}
